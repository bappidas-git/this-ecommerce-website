{
  "name": "this-ecommerce-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run sitemap",
    "build": "vite build",
    "preview": "vite preview",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "format": "prettier --write \"**/*.{js,jsx,css,md,json}\"",
