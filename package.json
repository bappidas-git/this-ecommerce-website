    "@mui/lab": "^9.0.0-beta.2",
    "@mui/material": "^9.0.0",
    "@mui/x-data-grid": "^9.0.4",
    "@mui/x-date-pickers": "^9.0.4",
    "axios": "^1.16.0",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.20",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "notistack": "^3.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
